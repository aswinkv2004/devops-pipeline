name:CI pipeline

on:
 push:
  branches:
   -main

 jobs:
   build:
    run: ubuntu-latest

   steps:
    -name:checkout code
     uses:actions/checkout@v5

     -name:set up node.js
      uses:actions/setups node@v3
       with:
        node version:16

     -name:install dependencies
     run:npm install

     -name:run test
     run:npm test