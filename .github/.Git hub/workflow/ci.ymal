name:ci pipeline

 on:
  push:
  branches:
   -main

   job:
   build:
    run:ubuntu-latest

    steps:
    -name:checkout code
    uses:action/checkout@v5

    -name:setup node.js
    uses:action/setup-nodev4
     with:
      node version:16

      -name:install dependencies
      run:npm install

      -name:run test
      run:npm tests
      